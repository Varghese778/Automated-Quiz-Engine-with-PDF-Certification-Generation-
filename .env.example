PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=quiz_db

# Comma-separated origins allowed to call the API from browsers
# Example: ALLOWED_ORIGINS=https://quiz.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Set to true when running behind reverse proxy / load balancer
TRUST_PROXY=false

# Strong random secret for certificate download token signing
CERT_TOKEN_SECRET=replace-with-a-long-random-secret

# Optional: enables Redis-backed sessions + rate limiting
# REDIS_URL=redis://localhost:6379
